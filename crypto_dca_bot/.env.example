# Telegram Bot (Phase 1)
# 1. Talk to @BotFather on Telegram to create a bot and obtain the token
# 2. Send any message to your bot, then GET
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Logging
LOG_LEVEL=INFO

# Binance (Phase 2 - leave empty until Phase 2)
BINANCE_API_KEY=
BINANCE_API_SECRET=
